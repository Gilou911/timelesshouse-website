# ──────────────────────────────────────────────────────────────
# Variables d'environnement TimelessHouse — TEMPLATE
# ──────────────────────────────────────────────────────────────
# 1) Copie ce fichier vers ".env.local" :
#       cp .env.example .env.local
# 2) Remplace les valeurs ci-dessous par celles de TON projet
#    Supabase (Dashboard Supabase > Project Settings > API).
# 3) ".env.local" est automatiquement exclu par .gitignore.
#
# IMPORTANT :
#  - Seules les variables préfixées par "VITE_" sont exposées
#    au code côté navigateur (Vite injecte leur valeur au build).
#  - La clé ANON est PUBLIQUE par conception (protégée par RLS).
#    Ne jamais mettre la clé service_role ici — elle reste
#    uniquement dans les Edge Functions Supabase.
#
# EN PRODUCTION (Cloudflare Pages) :
#  - Définis ces deux variables dans :
#       Cloudflare Pages > ton projet > Settings > Environment variables
#       (onglet "Production")
#  - Pas besoin de .env.production dans le repo.
# ──────────────────────────────────────────────────────────────

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key-here...

# ── Backblaze B2 (scripts locaux : encode-hls / setup-b2-cors) ──
# ⚠️ Ces variables ne sont PAS préfixées VITE_ : elles ne sont jamais
# exposées au navigateur. Elles servent uniquement aux scripts Node
# lancés en local. Les MÊMES valeurs (sauf service_role) sont aussi à
# renseigner dans les secrets de l'Edge Function b2-sign.
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
B2_REGION=eu-central-003
B2_BUCKET=timelesshouse-media
B2_KEY_ID=...
B2_APP_KEY=...
# Base publique des fichiers (SANS slash final) :
#   ▸ recommandé : domaine proxifié Cloudflare (egress B2 gratuit),
#     ex : https://media.timelesshouse.org/file/timelesshouse-media
#   ▸ sinon : URL friendly B2, ex : https://f003.backblazeb2.com/file/timelesshouse-media
B2_PUBLIC_BASE_URL=https://f003.backblazeb2.com/file/timelesshouse-media

# Service role : requise par scripts/encode-hls.mjs pour mettre à jour
# la fiche média. UNIQUEMENT en local (.env.local, jamais commitée).
SUPABASE_SERVICE_ROLE_KEY=eyJ...
