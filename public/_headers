# ════════════════════════════════════════════════════════════
# En-têtes HTTP servis par Cloudflare Pages
# ════════════════════════════════════════════════════════════
# Sans ce fichier, Cloudflare applique « max-age=0, must-revalidate »
# à TOUT — y compris aux bundles JS dont le nom porte déjà une
# empreinte de contenu (admin-CocKS2dj.js). Résultat : 6 allers-retours
# de revalidation à chaque ouverture de la console, pour des fichiers
# qui ne changent jamais. Audit du 20/07/2026.

# ── Ressources empreintées : cachables à vie ──
# Le nom change à chaque build, donc aucun risque de servir du périmé.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/icons/*
  Cache-Control: public, max-age=2592000

# ── Pages HTML : jamais mises en cache durablement ──
# Elles référencent les bundles empreintés ; une page périmée
# pointerait vers des fichiers disparus.
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# ── Sécurité, sur tout le site ──
/*
  # Interdit l'intégration du site dans une iframe tierce
  # (protection contre le détournement de clic).
  X-Frame-Options: DENY
  # Empêche un navigateur de « deviner » le type d'un fichier.
  X-Content-Type-Options: nosniff
  # Ne divulgue pas l'adresse d'origine vers les sites externes.
  Referrer-Policy: strict-origin-when-cross-origin
  # Aucune de ces API n'est utilisée par le produit.
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  # Force HTTPS pendant un an (les domaines .app l'imposent déjà,
  # cette ligne couvre laloge.house et timelesshouse.org).
  Strict-Transport-Security: max-age=31536000; includeSubDomains
