{
  "name": "timelesshouse",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "TimelessHouse — plateforme studio & agence (compilation Vite + Tailwind v4)",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/post-build.mjs loge",
    "build:studio": "vite build --config vite.config.studio.js && node scripts/post-build.mjs studio",
    "preview": "vite preview",
    "encode": "node scripts/encode-hls.mjs",
    "b2-cors": "node scripts/setup-b2-cors.mjs",
    "worker-encode": "node workers/encoder/worker-encode.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "hls.js": "^1.5.0",
    "lodash": "^4.18.1",
    "lucide-react": "^0.439.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/lib-storage": "^3.600.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "dotenv": "^16.4.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.0.0",
    "vite": "^5.4.21"
  }
}
